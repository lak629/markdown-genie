# Ignore editor and repository metadata
.vscode/**
.git/**
.gitignore
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*
coverage/**
**/coverage/**

# Ignore source files and build artifacts not needed in the published extension
src/**
**/*.ts
**/*.tsx
**/*.spec.*
**/*.test.*
**/*.log
**/tsconfig.json
**/package-lock.json
**/yarn.lock
**/README.md

# Ignore unneeded node_modules content
node_modules/**/test/**
node_modules/**/tests/**
node_modules/**/example/**
node_modules/**/examples/**
node_modules/**/demo/**
node_modules/**/docs/**
node_modules/**/doc/**
node_modules/**/benchmark/**
node_modules/**/scripts/**
node_modules/**/build/**
node_modules/**/coverage/**
node_modules/**/.bin/**
node_modules/**/.github/**
node_modules/**/.git/**
node_modules/**/*.map

# Ignore build output and packaged VSIX files
build/**
*.vsix

# Ignore non-extension files
**/*.md
**/*.markdown
**/*.pdf
**/*.zip
**/*.tgz
**/*.tar.gz
**/*.tsbuildinfo
